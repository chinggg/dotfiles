[core]
    editor = nvim
    autocrlf = input
    pager = delta

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[merge]
    conflictstyle = zdiff3

[diff]
    colorMoved = default

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    line-numbers = true

[alias]
    gl    = config --global -l
    lg    = log --oneline --graph --decorate --all
    ds    = diff --staged
    st    = status
    co    = checkout
    cm    = commit
    rv    = remote --verbose
    undo  = reset HEAD~1 --mixed
    amend = commit --amend --no-edit

# Personal identity and machine-specific overrides — not tracked
[include]
    path = ~/.gitconfig.local
